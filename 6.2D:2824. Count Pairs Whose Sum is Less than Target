import java.util.*;

public class Main {

    public static int countPairs(List<Integer> nums, int target) {

        Collections.sort(nums);

        int i = 0;
        int j = nums.size() - 1;
        int count = 0;

        while (i < j) {

        //T:o(n.log)
        //s:o(logn)
        //i
        //j

            int sum = nums.get(i) + nums.get(j);

            if (sum < target) {
                count += (j - i);
                i++;
            } else {
                j--;
            }
        }

        return count;
    }

    public static void main(String[] args) {

        List<Integer> nums = new ArrayList<>(Arrays.asList(-1, 1, 2, 3, 1));
        int target = 2;

        int result = countPairs(nums, target);

        System.out.println("Count of Pairs = " + result);
    }
}


///second metjhod
import java.util.*;

public class Main {

    public static int countPairs(List<Integer> nums, int target) {

        int count = 0;

        for (int i = 0; i < nums.size(); i++) {
            for (int j = i + 1; j < nums.size(); j++) {

                if (nums.get(i) + nums.get(j) < target) {
                    count++;
                }
            }
        }

        return count;
    }

    public static void main(String[] args) {

        List<Integer> nums = Arrays.asList(-1, 1, 2, 3, 1);
        int target = 2;

        int result = countPairs(nums, target);

        System.out.println("Count of Pairs = " + result);
    }
}
