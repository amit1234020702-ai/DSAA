class Solution {
    public int minSubArrayLen(int target, int[] nums) {
       int size= Integer.MAX_VALUE;
       int sum=0;
       int i=0;
       int j=0;
       //T:O(n) ,S:O(1)
       // 0 1 2 3
       // 2 3 1 6
       //i
       //j
       //sum=2
       //target=4
       while(j<nums.length){
        sum=sum+nums[j];
        while(sum>=target){
            size=Math.min(size,j-i+1);
            sum=sum-nums[i];
            i=i+1;
        }
        j=j+1;
       }
     return size==Integer.MAX_VALUE?0:size;
        
    }
}
