import java.util.*;

class Main {

    public static boolean isStrobogrammaticNumber(String s) {

        Map<Character, Character> map = new HashMap<>();

        map.put('0', '0');
        map.put('1', '1');
        map.put('8', '8');
        map.put('6', '9');
        map.put('9', '6');

        int i = 0;
        int j = s.length() - 1;
        
         //T:o(n) ,s:o(1)
        // 1 2 1
        //i
        //j
        //{0:0,1:1,6:9,8:8}
        //
        

        while (i <= j) {

            char left = s.charAt(i);
            char right = s.charAt(j);

            if (!map.containsKey(left) || map.get(left) != right) {
                return false;
            }

            i++;
            j--;
        }

        return true;
    }

    public static void main(String[] args) {

        String s = "198861";

        System.out.println(isStrobogrammaticNumber(s));
    }
}
