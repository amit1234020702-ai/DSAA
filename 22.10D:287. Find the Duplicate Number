class Solution {

    public int findDuplicate(int[] nums) {
        int ans = 0;

        for (int i = 0; i < nums.length; i++) {
            int ele = Math.abs(nums[i]);

            if (nums[ele] > 0) {
                nums[ele] = -nums[ele];
            } else {
                ans = ele;
                break;
            }
        }

        // Restore original array
        for (int i = 0; i < nums.length; i++) {
            nums[i] = Math.abs(nums[i]);
        }

        return ans;
    }
}

public class Main {

    public static void main(String[] args) {

        int[] nums = {1, 3, 4, 2, 2};

        Solution obj = new Solution();

        int duplicate = obj.findDuplicate(nums);

        System.out.println("Duplicate Element = " + duplicate);

        // Print original array (restored)
        System.out.print("Array: ");
        for (int num : nums) {
            System.out.print(num + " ");
        }
    }
}




// slow fast method
class Solution {

    public int findDuplicate(int[] nums) {

        int slow = 0;
        int fast = 0;

        // Phase 1: Find intersection point
        do {
            slow = nums[slow];
            fast = nums[nums[fast]];
        } while (slow != fast);

        // Phase 2: Find entrance of cycle
        int n1 = 0;
        int n2 = slow;

        while (n1 != n2) {
            n1 = nums[n1];
            n2 = nums[n2];
        }

        return n1;
    }
}

public class Main {

    public static void main(String[] args) {

        int[] nums = {1, 3, 4, 2, 2};

        Solution obj = new Solution();

        int duplicate = obj.findDuplicate(nums);

        System.out.println("Duplicate Element = " + duplicate);
    }
}
