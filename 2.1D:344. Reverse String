class Solution {

    public void reverseString(char[] s) {

        int i = 0;
        int j = s.length - 1;
        // hello
        //i
        //j
        //temp=e

        //T:O(n)
        //T:O(1)

        while (i < j) {

            char temp = s[i];
            s[i] = s[j];
            s[j] = temp;

            i++;
            j--;
        }
    }
}

public class Main {

    public static void main(String[] args) {

        Solution obj = new Solution();

        char[] s = {'h', 'e', 'l', 'l', 'o'};

        System.out.print("Before Reverse: ");
        for (char ch : s) {
            System.out.print(ch);
        }

        obj.reverseString(s);

        System.out.print("\nAfter Reverse: ");
        for (char ch : s) {
            System.out.print(ch);
        }
    }
}
