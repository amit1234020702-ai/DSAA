class Solution {
    public double findMaxAverage(int[] nums, int k) {
      double max=0,
      sum=0;
//       0 1   2  3 4  5  
      // 1 12 -5 -6 50 3
      //i
      //max=0;
      //sum=0;
      //k=4
      for(int i=0;i<k;i++){
        sum=sum+nums[i];
      }  
      max=sum;
      for(int i=k;i<nums.length;i++){
        sum=sum+nums[i];
        sum=sum-nums[i-k];
        max=Math.max(max,sum);
      }
      return max/k;
    }
}
